MiscTab:CreateButton("Server Hop", function()
    local Http = game:GetService("HttpService")
    local TPS = game:GetService("TeleportService")
    local Api = "https://games.roblox.com/v1/games/"
    
    local request = http_request or request or HttpPost or syn.request
    local url = Api .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    
    local success, result = pcall(function()
        if syn then
            return request({Url = url, Method = "GET"})
        else
            return game:HttpGet(url)
        end
    end)
    
    if success then
        local body = type(result) == "table" and result.Body or result
        local data = HttpService:JSONDecode(body)
        if data and data.data and #data.data > 0 then
            local server = data.data[math.random(1, #data.data)]
            TPS:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
        end
    end
end)

