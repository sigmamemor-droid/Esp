local function IsSameTeam(player1, player2)
    if player1.Team and player2.Team and player1.Team == player2.Team then
        return true
    end
    if player1.TeamColor and player2.TeamColor and player1.TeamColor == player2.TeamColor then
        return true
    end
    return false
end

local function HideAllESP(objects)
    objects.Box.Visible = false
    objects.Tracer.Visible = false
    objects.NameTag.Visible = false
    objects.DistanceTag.Visible = false
    objects.HealthBarBG.Visible = false
    objects.HealthBar.Visible = false
end

function CreateESP(player)
    local box = Drawing.new("Square")
    box.Visible = false
    box.Color = EspSettings.BoxColor
    box.Thickness = 2
    box.Filled = false
    box.Transparency = 1

    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = EspSettings.TracerColor
    tracer.Thickness = 1
    tracer.Transparency = 1

    local nameTag = Drawing.new("Text")
    nameTag.Visible = false
    nameTag.Color = EspSettings.NameColor
    nameTag.Size = 14
    nameTag.Center = true
    nameTag.Outline = true
    nameTag.OutlineColor = Color3.new(0, 0, 0)

    local distanceTag = Drawing.new("Text")
    distanceTag.Visible = false
    distanceTag.Color = EspSettings.NameColor
    distanceTag.Size = 12
    distanceTag.Center = true
    distanceTag.Outline = true
    distanceTag.OutlineColor = Color3.new(0, 0, 0)

    local healthBarBG = Drawing.new("Square")
    healthBarBG.Visible = false
    healthBarBG.Color = Color3.new(0, 0, 0)
    healthBarBG.Filled = true

    local healthBar = Drawing.new("Square")
    healthBar.Visible = false
    healthBar.Color = Color3.new(0, 255, 0)
    healthBar.Filled = true

    EspObjects[player] = {
        Box = box,
        Tracer = tracer,
        NameTag = nameTag,
        DistanceTag = distanceTag,
        HealthBarBG = healthBarBG,
        HealthBar = healthBar
    }
end

function RemoveESP(player)
    local objects = EspObjects[player]
    if not objects then return end

    for _, obj in pairs(objects) do
        pcall(function()
            if obj and obj.Remove then
                obj:Remove()
            elseif obj then
                obj.Visible = false
            end
        end)
    end
    EspObjects[player] = nil
end

function UpdateESP(player, objects)
    if not EspSettings.Enabled then
        HideAllESP(objects)
        return
    end

    local character = player.Character
    if not character then
        HideAllESP(objects)
        return
    end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local head = character:FindFirstChild("Head")

    if not humanoid or not rootPart then
        HideAllESP(objects)
        return
    end

    if humanoid.Health <= 0 then
        HideAllESP(objects)
        return
    end

    if EspSettings.TeamCheck and IsSameTeam(player, LocalPlayer) then
        HideAllESP(objects)
        return
    end

    local myChar = LocalPlayer.Character
    if not myChar then
        HideAllESP(objects)
        return
    end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then
        HideAllESP(objects)
        return
    end

    local distance = (rootPart.Position - myRoot.Position).Magnitude
    if distance > EspSettings.MaxDistance then
        HideAllESP(objects)
        return
    end

    local rootPos, rootOnScreen = Camera:WorldToViewportPoint(rootPart.Position)
    if not rootOnScreen then
        HideAllESP(objects)
        return
    end

    local headTopPos
    if head then
        pcall(function()
            headTopPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1.5, 0))
        end)
    end

    -- Коробка
    if EspSettings.Boxes then
        local scale = 1000 / math.max(rootPos.Z, 1)
        local boxWidth = math.clamp(scale * 1.8, 20, 200)
        local boxHeight = math.clamp(scale * 3.5, 40, 350)
        objects.Box.Size = Vector2.new(boxWidth, boxHeight)
        objects.Box.Position = Vector2.new(rootPos.X - boxWidth / 2, rootPos.Y - boxHeight / 2)
        objects.Box.Visible = true
        objects.Box.Color = EspSettings.BoxColor
    else
        objects.Box.Visible = false
    end

    -- Трейсер
    if EspSettings.Tracers then
        objects.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
        objects.Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
        objects.Tracer.Visible = true
        objects.Tracer.Color = EspSettings.TracerColor
    else
        objects.Tracer.Visible = false
    end

    -- Имя
    if EspSettings.Names then
        local namePos = rootPos
        if headTopPos and headTopPos.Z > 0 then
            namePos = headTopPos
        end
        local screenX = math.clamp(namePos.X, 20, Camera.ViewportSize.X - 20)
        local screenY = math.clamp(namePos.Y - 25, 10, Camera.ViewportSize.Y - 10)
        objects.NameTag.Position = Vector2.new(screenX, screenY)
        objects.NameTag.Text = player.Name
        objects.NameTag.Visible = true
        objects.NameTag.Color = EspSettings.NameColor
    else
        objects.NameTag.Visible = false
    end

    -- Дистанция
    if EspSettings.Distance then
        local distY = math.clamp(rootPos.Y + 15, 20, Camera.ViewportSize.Y - 5)
        objects.DistanceTag.Position = Vector2.new(
            math.clamp(rootPos.X, 30, Camera.ViewportSize.X - 30),
            distY
        )
        objects.DistanceTag.Text = math.floor(distance) .. "m"
        objects.DistanceTag.Visible = true
        objects.DistanceTag.Color = EspSettings.NameColor
    else
        objects.DistanceTag.Visible = false
    end

    -- HealthBar
    if EspSettings.HealthBar then
        local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
        local scale = 1000 / math.max(rootPos.Z, 1)
        local boxHeight = math.clamp(scale * 3.5, 40, 350)
        local boxWidth = math.clamp(scale * 1.8, 20, 200)
        local boxX = rootPos.X - boxWidth / 2

        local barWidth = 3
        local barX = boxX - 6
        local barY = rootPos.Y - boxHeight / 2
        local barFullHeight = boxHeight

        objects.HealthBarBG.Size = Vector2.new(barWidth, barFullHeight)
        objects.HealthBarBG.Position = Vector2.new(barX, barY)
        objects.HealthBarBG.Visible = true

        local filledHeight = barFullHeight * healthPercent
        objects.HealthBar.Size = Vector2.new(barWidth, filledHeight)
        objects.HealthBar.Position = Vector2.new(barX, barY + barFullHeight - filledHeight)
        objects.HealthBar.Color = Color3.new(1 - healthPercent, healthPercent, 0)
        objects.HealthBar.Visible = true
    else
        objects.HealthBarBG.Visible = false
        objects.HealthBar.Visible = false
    end
end

function StartESP()
    if EspActive then return end
    EspActive = true

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            CreateESP(player)
        end
    end

    EspConnections.PlayerAdded = Players.PlayerAdded:Connect(function(player)
        if player ~= LocalPlayer then
            CreateESP(player)
        end
    end)

    EspConnections.PlayerRemoving = Players.PlayerRemoving:Connect(function(player)
        RemoveESP(player)
    end)

    renderSteppedConnection = RunService.RenderStepped:Connect(function()
        if not EspActive or not EspSettings.Enabled then return end
        for player, objects in pairs(EspObjects) do
            UpdateESP(player, objects)
        end
    end)

    print("// SWILL ESP: ACTIVATED")
end

function StopESP()
    EspActive = false

    for player, _ in pairs(EspObjects) do
        RemoveESP(player)
    end

    if EspConnections.PlayerAdded then
        EspConnections.PlayerAdded:Disconnect()
        EspConnections.PlayerAdded = nil
    end
    if EspConnections.PlayerRemoving then
        EspConnections.PlayerRemoving:Disconnect()
        EspConnections.PlayerRemoving = nil
    end
    if renderSteppedConnection then
        renderSteppedConnection:Disconnect()
        renderSteppedConnection = nil
    end

    EspObjects = {}
    print("// SWILL ESP: DEACTIVATED")
end

