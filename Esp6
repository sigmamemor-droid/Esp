-- КОНФИГУРАЦИЯ ESP
local ESPConfig = {
    Enabled = true,
    Traceline = true,
    Box = true,
    HealthBar = true,
    HealthText = true,
    NameDisplay = true,
    Distance = true,
    MaxRenderDistance = 500,
    BoxColor = Color3.fromRGB(0, 255, 255),
    TracelineColor = Color3.fromRGB(255, 0, 255),
    TeamCheck = false,
    UseTeamColors = true
}

-- ХРАНИЛИЩЕ ОБЪЕКТОВ ESP
local ESPObjects = {}

-- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
local function CreateDrawingObject(drawType, color)
    local obj
    if drawType == "Line" then
        obj = Drawing.new("Line")
        obj.Thickness = 2
        obj.Color = color
        obj.Visible = false
        obj.Transparency = 1
    elseif drawType == "Square" then
        obj = Drawing.new("Square")
        obj.Thickness = 2
        obj.Filled = false
        obj.Color = color
        obj.Visible = false
        obj.Transparency = 1
    elseif drawType == "Text" then
        obj = Drawing.new("Text")
        obj.Size = 14
        obj.Center = true
        obj.Outline = true
        obj.Color = color
        obj.Visible = false
        obj.Font = 3  -- UI.Font.Gotham
    end
    return obj
end

local function GetHealthColor(health, maxHealth)
    local percent = health / maxHealth
    local r = 1 - percent
    local g = percent
    return Color3.fromRGB(r * 255, g * 255, 0)
end

local function GetTeamColor(player)
    if player.Team then
        if player.Team.TeamColor then
            return player.Team.TeamColor.Color
        end
    end
    return ESPConfig.BoxColor
end

-- ОСНОВНАЯ ФУНКЦИЯ ОТРИСОВКИ ESP
local function DrawESP(player)
    if not ESPConfig.Enabled then return end
    if player == LocalPlayer then return end
    
    local character = player.Character
    if not character or not character.Parent then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    if not rootPart or not humanoid or humanoid.Health <= 0 then
        if ESPObjects[player] then
            for _, obj in pairs(ESPObjects[player]) do
                if obj then obj.Visible = false end
            end
        end
        return
    end
    
    -- ПРОВЕРКА ДИСТАНЦИИ
    local distance = (Camera.CFrame.Position - rootPart.Position).Magnitude
    if distance > ESPConfig.MaxRenderDistance then
        if ESPObjects[player] then
            for _, obj in pairs(ESPObjects[player]) do
                if obj then obj.Visible = false end
            end
        end
        return
    end
    
    -- ПОЛУЧЕНИЕ ПОЗИЦИЙ НА ЭКРАНЕ
    local screenPos, onScreen = Camera:WorldToScreenPoint(rootPart.Position)
    if not onScreen then return end
    
    local head = character:FindFirstChild("Head")
    local headPos = head and head.Position or rootPart.Position + Vector3.new(0, 2.5, 0)
    local headScreen, headOnScreen = Camera:WorldToScreenPoint(headPos)
    
    if not headOnScreen then return end
    
    -- РАСЧЕТ РАЗМЕРОВ БОКСА
    local height = math.abs(headScreen.Y - screenPos.Y)
    local width = height * 0.6
    if height < 10 or width < 5 then return end
    
    local centerX = screenPos.X
    local boxMinX = centerX - width/2
    local boxMinY = headScreen.Y
    local boxMaxX = centerX + width/2
    local boxMaxY = screenPos.Y
    
    -- ОПРЕДЕЛЕНИЕ ЦВЕТОВ
    local boxColor = ESPConfig.BoxColor
    local tracelineColor = ESPConfig.TracelineColor
    
    if ESPConfig.TeamCheck and ESPConfig.UseTeamColors then
        boxColor = GetTeamColor(player)
        tracelineColor = boxColor
    elseif ESPConfig.TeamCheck and player.Team and LocalPlayer.Team then
        if player.Team == LocalPlayer.Team then
            boxColor = Color3.fromRGB(0, 255, 0)
            tracelineColor = Color3.fromRGB(0, 255, 0)
        else
            boxColor = Color3.fromRGB(255, 0, 0)
            tracelineColor = Color3.fromRGB(255, 0, 0)
        end
    end
    
    local healthPercent = humanoid.Health / humanoid.MaxHealth
    
    -- СОЗДАНИЕ ОБЪЕКТОВ ЕСЛИ ИХ НЕТ
    if not ESPObjects[player] then
        ESPObjects[player] = {
            Box = CreateDrawingObject("Square", boxColor),
            Traceline = CreateDrawingObject("Line", tracelineColor),
            NameText = CreateDrawingObject("Text", Color3.fromRGB(255, 255, 255)),
            HealthText = CreateDrawingObject("Text", Color3.fromRGB(255, 255, 255)),
            DistanceText = CreateDrawingObject("Text", Color3.fromRGB(200, 200, 200)),
            HealthBar = Drawing.new("Line")
        }
        ESPObjects[player].HealthBar.Thickness = 3
        ESPObjects[player].HealthBar.Color = GetHealthColor(humanoid.Health, humanoid.MaxHealth)
        ESPObjects[player].HealthBar.Visible = false
    end
    
    local esp = ESPObjects[player]
    
    -- ОТРИСОВКА BOX
    if ESPConfig.Box then
        esp.Box.Visible = true
        esp.Box.Color = boxColor
        esp.Box.Size = Vector2.new(width, height)
        esp.Box.Position = Vector2.new(boxMinX, boxMinY)
    else
        esp.Box.Visible = false
    end
    
    -- ОТРИСОВКА TRACELINE (ЛИНИЯ ОТ ЦЕНТРА ЭКРАНА)
    if ESPConfig.Traceline then
        esp.Traceline.Visible = true
        esp.Traceline.Color = tracelineColor
        esp.Traceline.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
        esp.Traceline.To = Vector2.new(centerX, boxMaxY)
    else
        esp.Traceline.Visible = false
    end
    
    -- ОТРИСОВКА HEALTH BAR
    if ESPConfig.HealthBar then
        esp.HealthBar.Visible = true
        esp.HealthBar.Color = GetHealthColor(humanoid.Health, humanoid.MaxHealth)
        esp.HealthBar.From = Vector2.new(boxMinX - 5, boxMaxY - (height * healthPercent))
        esp.HealthBar.To = Vector2.new(boxMinX - 5, boxMaxY)
        esp.HealthBar.Thickness = 3
    else
        esp.HealthBar.Visible = false
    end
    
    -- ОТРИСОВКА HEALTH TEXT
    if ESPConfig.HealthText then
        esp.HealthText.Visible = true
        esp.HealthText.Text = math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth)
        esp.HealthText.Position = Vector2.new(centerX, boxMaxY + 15)
        esp.HealthText.Size = 11
        esp.HealthText.Color = GetHealthColor(humanoid.Health, humanoid.MaxHealth)
    else
        esp.HealthText.Visible = false
    end
    
    -- ОТРИСОВКА NAME
    if ESPConfig.NameDisplay then
        esp.NameText.Visible = true
        local nameText = player.DisplayName or player.Name
        if distance < 20 then
            nameText = nameText .. " [В БЛИЗИ]"
        end
        esp.NameText.Text = nameText
        esp.NameText.Position = Vector2.new(centerX, boxMinY - 15)
        esp.NameText.Color = boxColor
        esp.NameText.Size = 14
    else
        esp.NameText.Visible = false
    end
    
    -- ОТРИСОВКА DISTANCE
    if ESPConfig.Distance then
        esp.DistanceText.Visible = true
        local distText = math.floor(distance) .. "м"
        if distance < 50 then
            distText = "⚠️ " .. distText .. " ⚠️"
            esp.DistanceText.Color = Color3.fromRGB(255, 100, 100)
        else
            esp.DistanceText.Color = Color3.fromRGB(255, 255, 255)
        end
        esp.DistanceText.Text = distText
        esp.DistanceText.Position = Vector2.new(centerX, boxMaxY + 28)
        esp.DistanceText.Size = 10
    else
        esp.DistanceText.Visible = false
    end
end

-- ОЧИСТКА ESP
local function ClearESP(player)
    if ESPObjects[player] then
        for _, obj in pairs(ESPObjects[player]) do
            if obj and obj.Remove then
                pcall(function() obj:Remove() end)
            end
        end
        ESPObjects[player] = nil
    end
end

-- ОЧИСТКА ВСЕГО ESP
local function ClearAllESP()
    for player, _ in pairs(ESPObjects) do
        ClearESP(player)
    end
end

-- ОСНОВНОЙ ЦИКЛ ОТРИСОВКИ
RunService.RenderStepped:Connect(function()
    if not ESPConfig.Enabled then 
        ClearAllESP()
        return 
    end
    
    for _, player in pairs(Players:GetPlayers()) do
        pcall(function() DrawESP(player) end)
    end
end)

-- ОБРАБОТКА ВЫХОДА ИГРОКОВ
Players.PlayerRemoving:Connect(function(player)
    ClearESP(player)
end)

-- ОБРАБОТКА ПЕРЕРОЖДЕНИЯ
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    ClearAllESP()
end)

-- ГЛОБАЛЬНЫЕ ФУНКЦИИ УПРАВЛЕНИЯ
_G.SetESPEnabled = function(enabled)
    ESPConfig.Enabled = enabled
    if not enabled then ClearAllESP() end
end

_G.SetESPConfig = function(config)
    for k, v in pairs(config) do
        ESPConfig[k] = v
    end
end

_G.GetESPConfig = function()
    return ESPConfig
end

