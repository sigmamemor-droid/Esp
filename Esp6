UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        local mousePos = UserInputService:GetMouseLocation().X
        for _, slider in ipairs(activeSliders) do
            if slider.isDragging() then
                local bgAbsPos = slider.bg.AbsolutePosition.X
                local bgAbsSize = slider.bg.AbsoluteSize.X
                local percent = math.clamp((mousePos - bgAbsPos) / bgAbsSize, 0, 1)
                local value = math.floor(slider.min + (slider.max - slider.min) * percent)
                slider.updateDisplay(percent, value)
                slider.callback(value)
            end
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        for _, slider in ipairs(activeSliders) do
            slider.setDragging(false)
        end
    end
end)

