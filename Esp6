-- ESP Отрисовка
local ESPObjects = {}
local function CreateESP(player)
    local espObj = {
        Box = Drawing.new("Square"),
        Tracer = Drawing.new("Line"),
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        HealthBar = Drawing.new("Line"),
        HealthBG = Drawing.new("Line"),
        SkeletonLines = {}
    }
    
    -- Настройка бокса
    espObj.Box.Visible = false
    espObj.Box.Thickness = ESP.BoxThickness
    espObj.Box.Filled = false
    espObj.Box.Color = ESP.BoxColor
    
    -- Настройка трейсера
    espObj.Tracer.Visible = false
    espObj.Tracer.Thickness = ESP.TracerThickness
    espObj.Tracer.Color = ESP.TracerColor
    
    -- Настройка имени
    espObj.Name.Visible = false
    espObj.Name.Size = ESP.NameSize
    espObj.Name.Center = true
    espObj.Name.Outline = true
    espObj.Name.Color = ESP.NameColor
    
    -- Настройка дистанции
    espObj.Distance.Visible = false
    espObj.Distance.Size = 13
    espObj.Distance.Center = true
    espObj.Distance.Outline = true
    espObj.Distance.Color = ESP.DistanceColor
    
    -- Скелет
    for i = 1, 15 do
        local line = Drawing.new("Line")
        line.Visible = false
        line.Color = ESP.SkeletonColor
        line.Thickness = 1
        espObj.SkeletonLines[i] = line
    end
    
    ESPObjects[player] = espObj
    return espObj
end

-- Обновление ESP
local function UpdateESP()
    for player, espObj in pairs(ESPObjects) do
        if player == LocalPlayer or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            for _, drawing in pairs(espObj) do
                if type(drawing) == "table" then
                    for _, d in pairs(drawing) do
                        if d and d.Remove then d.Visible = false end
                    end
                elseif drawing and drawing.Remove then
                    drawing.Visible = false
                end
            end
            continue
        end
        
        if ESP.TeamCheck and player.Team == LocalPlayer.Team then
            for _, drawing in pairs(espObj) do
                if type(drawing) == "table" then
                    for _, d in pairs(drawing) do
                        if d and d.Remove then d.Visible = false end
                    end
                elseif drawing and drawing.Remove then
                    drawing.Visible = false
                end
            end
            continue
        end
        
        local rootPart = player.Character.HumanoidRootPart
        local humanoid = player.Character:FindFirstChild("Humanoid")
        local screenPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
        
        local distance = (Camera.CFrame.Position - rootPart.Position).Magnitude
        if distance > ESP.MaxDistance then
            for _, drawing in pairs(espObj) do
                if type(drawing) == "table" then
                    for _, d in pairs(drawing) do
                        if d and d.Remove then d.Visible = false end
                    end
                elseif drawing and drawing.Remove then
                    drawing.Visible = false
                end
            end
            continue
        end
        
        -- Боксы
        if ESP.Boxes and ESP.Enabled then
            espObj.Box.Visible = onScreen
            if onScreen then
                local boxSize = Vector2.new(math.floor(2000 / distance), math.floor(3500 / distance))
                espObj.Box.Size = boxSize
                espObj.Box.Position = Vector2.new(screenPos.X - boxSize.X/2, screenPos.Y - boxSize.Y/2)
                espObj.Box.Color = ESP.BoxColor
                espObj.Box.Thickness = ESP.BoxThickness
            end
        else
            espObj.Box.Visible = false
        end
        
        -- Трейсеры
        if ESP.Tracers and ESP.Enabled then
            espObj.Tracer.Visible = onScreen
            if onScreen then
                local viewportSize = Camera.ViewportSize
                espObj.Tracer.From = Vector2.new(viewportSize.X/2, viewportSize.Y)
                espObj.Tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                espObj.Tracer.Color = ESP.TracerColor
            end
        else
            espObj.Tracer.Visible = false
        end
        
        -- Имена
        if ESP.Names and ESP.Enabled then
            espObj.Name.Visible = onScreen
            if onScreen then
                espObj.Name.Text = player.Name
                espObj.Name.Position = Vector2.new(screenPos.X, screenPos.Y - math.floor(2500 / distance) - 20)
                espObj.Name.Color = ESP.NameColor
            end
        else
            espObj.Name.Visible = false
        end
        
        -- Дистанция
        if ESP.Distance and ESP.Enabled then
            espObj.Distance.Visible = onScreen
            if onScreen then
                espObj.Distance.Text = string.format("[%.0f m]", distance)
                espObj.Distance.Position = Vector2.new(screenPos.X, screenPos.Y - math.floor(2500 / distance) - 35)
                espObj.Distance.Color = ESP.DistanceColor
            end
        else
            espObj.Distance.Visible = false
        end
        
        -- Health Bar
        if ESP.HealthBar and humanoid and ESP.Enabled then
            espObj.HealthBar.Visible = onScreen
            espObj.HealthBG.Visible = onScreen
            if onScreen then
                local boxSize = Vector2.new(math.floor(2000 / distance), math.floor(3500 / distance))
                local healthPercent = humanoid.Health / humanoid.MaxHealth
                
                espObj.HealthBG.From = Vector2.new(screenPos.X - boxSize.X/2 - 6, screenPos.Y - boxSize.Y/2)
                espObj.HealthBG.To = Vector2.new(screenPos.X - boxSize.X/2 - 6, screenPos.Y + boxSize.Y/2)
                espObj.HealthBG.Color = Color3.fromRGB(0, 0, 0)
                espObj.HealthBG.Thickness = 3
                
                espObj.HealthBar.From = Vector2.new(screenPos.X - boxSize.X/2 - 6, screenPos.Y + boxSize.Y/2)
                espObj.HealthBar.To = Vector2.new(screenPos.X - boxSize.X/2 - 6, screenPos.Y + boxSize.Y/2 - boxSize.Y * healthPercent)
                espObj.HealthBar.Color = Color3.fromHSV(healthPercent * 0.3, 1, 1)
                espObj.HealthBar.Thickness = 3
            end
        else
            espObj.HealthBar.Visible = false
            espObj.HealthBG.Visible = false
        end
        
        -- Скелет
        if ESP.Skeletons and ESP.Enabled then
            local connections = {
                {"Head", "UpperTorso"},
                {"UpperTorso", "LowerTorso"},
                {"UpperTorso", "LeftUpperArm"},
                {"LeftUpperArm", "LeftLowerArm"},
                {"LeftLowerArm", "LeftHand"},
                {"UpperTorso", "RightUpperArm"},
                {"RightUpperArm", "RightLowerArm"},
                {"RightLowerArm", "RightHand"},
                {"LowerTorso", "LeftUpperLeg"},
                {"LeftUpperLeg", "LeftLowerLeg"},
                {"LeftLowerLeg", "LeftFoot"},
                {"LowerTorso", "RightUpperLeg"},
                {"RightUpperLeg", "RightLowerLeg"},
                {"RightLowerLeg", "RightFoot"}
            }
            
            for i, conn in ipairs(connections) do
                local part1 = player.Character:FindFirstChild(conn[1])
                local part2 = player.Character:FindFirstChild(conn[2])
                
                if part1 and part2 then
                    local pos1, vis1 = Camera:WorldToViewportPoint(part1.Position)
                    local pos2, vis2 = Camera:WorldToViewportPoint(part2.Position)
                    
                    if vis1 and vis2 and espObj.SkeletonLines[i] then
                        espObj.SkeletonLines[i].Visible = true
                        espObj.SkeletonLines[i].From = Vector2.new(pos1.X, pos1.Y)
                        espObj.SkeletonLines[i].To = Vector2.new(pos2.X, pos2.Y)
                        espObj.SkeletonLines[i].Color = ESP.SkeletonColor
                    elseif espObj.SkeletonLines[i] then
                        espObj.SkeletonLines[i].Visible = false
                    end
                elseif espObj.SkeletonLines[i] then
                    espObj.SkeletonLines[i].Visible = false
                end
            end
        else
            for _, line in ipairs(espObj.SkeletonLines) do
                if line then line.Visible = false end
            end
        end
    end
end

